;;;             +--------------------------------------------------+

;;; +------------------------------------------------------------------------+
;;; | disp_main_win                                                          |
;;; +------------------------------------------------------------------------+
disp_main_win:
	push ax
	push bx
	push cx
	push dx
	push bp

	;; ecrire le titre
	mov ax, 0x1301
	mov bh, 0
	mov bl, 0x1f
	mov cx, 80
	mov dh, 0
	mov dl, 0
	mov bp, $main_win_title
	int 0x10

        ;; dessiner le haut du cadre
	mov bl, 7
        mov bp, $main_win_up
	inc dh
	int 0x10

	;; dessiner les 21 lignes interieures
	mov cx, 21
	mov bp, $main_win_middle
main_win_disp_middle:
	push cx
	mov cx, 80
	inc dh
	int 0x10
	pop cx
	loop $main_win_disp_middle

	;; dessiner le bas du cadre
	mov cx, 80
	mov bp, $main_win_down
	inc dh
	int 0x10

	pop bp
	pop dx
	pop cx
	pop bx
	pop ax
	ret

;;; +-------------------------------------------------------------------------+
;;; | Add_item                                                                |
;;; | entree:                                                                 |
;;; |    ES:SI = chaine                                                       |
;;; +-------------------------------------------------------------------------+
add_item:
	push ax
	push bx
	push cx
	push dx
	push bp
	push di
	push ds

	;; aucune verification du numero de l'item mais il doit etre compris
        ;; entre 1 et 21
	;; de meme pour la taille de la chaine qui doit etre comprise entre
	;; 1 et 76

	call $strlen

	mov ax, cs
	mov ds, ax
	
	inc byte [$nb_items]
	mov dh, [$nb_items]
	inc dh
        mov ax, 0x1301
	mov bh, 0
	mov bl, 7
	mov dl, 2
	mov bp, si
	int 0x10

	;; placer l'adresse de la chaine dans la liste
	mov di, $items
	mov ax, 0
	mov al, [$nb_items]
	dec al
	shl ax, 1 ; ax * 2
	add di, ax
	mov [di], bp

	pop ds
	pop di
	pop bp
	pop dx
	pop cx
	pop bx
	pop ax
	ret

;;; +-------------------------------------------------------------------------+
;;; | unselect_item                                                           |
;;; | entree : al = numero de l'item                                          |
;;; +-------------------------------------------------------------------------+
unselect_item:
	push ax
	push bx
	push cx
	push dx
	push bp
	push di
	push si
	
	push ax
	mov di, $items
	mov ah, 0
	dec al
	shl ax, 1
	add di, ax
	mov bp, [di]
	mov si, bp
	pop ax

	mov dh, al
	inc dh
        mov ax, 0x1301
	mov bh, 0
	mov bl, 7
	call $strlen
	mov dl, 2
	int 0x10
	
	pop si
	pop di
	pop bp
	pop dx
	pop cx
	pop bx
	pop ax
	ret

;;; +-------------------------------------------------------------------------+
;;; | select_item                                                             |
;;; | entree : al = numero de l'item                                          |
;;; | sortie : al = item selectionnee                                         |
;;; +-------------------------------------------------------------------------+
select_item:
	push bx
	push cx
	push dx
	push bp
	push di
	push si
	push ax

	cmp [$nb_items], al
	jc $select_over
	cmp al, 0
	jz $select_under
	jmp $select_ok
select_over:
	mov al, [$nb_items]
	jmp $select_ok
select_under:
	mov al, 1
select_ok:
	push ax
	mov di, $items
	mov ah, 0
	dec al
	shl ax, 1
	add di, ax
	mov bp, [di]
	mov si, bp
	pop ax

	mov dh, al
	inc dh
        mov ax, 0x1301
	mov bh, 0
	mov bl, 0x1f
	call $strlen
	mov dl, 2
	int 0x10

	pop ax
	mov al, dh
	dec al

	pop si
	pop di
	pop bp
	pop dx
	pop cx
	pop bx
	ret

;;; +-------------------------------------------------------------------------+
;;; | main_loop                                                               |
;;; +-------------------------------------------------------------------------+
main_loop:
	mov ah, 0
	int 0x16

	cmp ah, 0x50
	jz $event_down
	cmp ah, 0x48
	jz $event_up
	cmp ah, 0x4f
	jz $event_end
	cmp ah, 0x47
	jz $event_origin
	cmp al, 13
	jz $event_select

	jmp $main_loop

event_down:
	mov al, [$selected_item]
	call $unselect_item
	inc al
	call $select_item
	mov [$selected_item], al
	jmp $main_loop

event_up:
	mov al, [$selected_item]
	call $unselect_item
	dec al
	call $select_item
	mov [$selected_item], al
	jmp $main_loop

event_end:
	mov al, [$selected_item]
	call $unselect_item
	mov al, [$nb_items]
	call $select_item
	mov [$selected_item], al
	jmp $main_loop

event_origin:
	mov al, [$selected_item]
	call $unselect_item
	mov al, 1
	call $select_item
	mov [$selected_item], al
	jmp $main_loop

event_select:
	jmp $selected

;;; +-------------------------------------------------------------------------+
;;; | init_interf                                                             |
;;; +-------------------------------------------------------------------------+
init_interf:
	push ax
	push cx

	;; effacer le curseur
	mov ah, 1
	mov cx, 0x100
	int 0x10

	mov byte [$nb_items], 0

	pop cx
	pop ax
	ret

;;; +-------------------------------------------------------------------------+
;;; | dialog                                                                  |
;;; | entree : ds:si = message                                                |
;;; +-------------------------------------------------------------------------+
dialog:
	push ax
	push bx
	push cx
	push dx
	push bp

	;; ecrire le titre
	mov ax, 0x1301
	mov bh, 0
	mov bl, 0x1f
	mov cx, 40
	mov dh, 9
	mov dl, 20
	mov bp, $dialog_title
	int 0x10

        ;; dessiner le haut du cadre
	mov bl, 7
        mov bp, $dialog_up
	inc dh
	int 0x10

	;; dessiner les 3 lignes interieures
	mov bp, $dialog_middle
	inc dh
	int 0x10
	inc dh
	int 0x10
	inc dh
	int 0x10 

	;; ecrire le message
	add dl, 2
	dec dh
	mov bp, si
	call $strlen
	int 0x10
	sub dl, 2
	inc dh

	;; dessiner le bas du cadre
	mov cx, 40
	mov bp, $dialog_down
	inc dh
	int 0x10

	pop bp
	pop dx
	pop cx
	pop bx
	pop ax
	ret

;;; +-------------------------------------------------------------------------+
;;; | inputbox                                                                |
;;; | entree : ds:si = message                                                |
;;; |          es:di = buffer pour la reponse                                 |
;;; |          cx = nombre max de caracteres                                  |
;;; +-------------------------------------------------------------------------+
inputbox:
	push ax
	push bx
	push cx
	push dx
	push bp

	push es
	push cx

	mov ax, cs
	mov es, ax

	;; ecrire le titre
	mov ax, 0x1301
	mov bh, 0
	mov bl, 0x1f
	mov cx, 40
	mov dh, 10
	mov dl, 20
	mov bp, $dialog_title
	int 0x10

        ;; dessiner le haut du cadre
	mov bl, 7
        mov bp, $dialog_up
	inc dh
	int 0x10

	;; dessiner les deux lignes interieures
	mov bp, $dialog_middle
	inc dh
	int 0x10
	inc dh
	int 0x10

	;; ecrire le message
	dec dh
	add dl, 2
	mov bp, si
	call $strlen
	int 0x10
	sub dl, 2
	inc dh

	;; dessiner le bas du cadre
	mov cx, 40
	mov bp, $dialog_down
	inc dh
	int 0x10

	pop cx
	push cx

        ;; dessiner la zone de texte
	dec dh
	mov bp, $textarea
	add dl, 2
	int 0x10
	
	;; afficher le curseur
	mov bh, 0
	mov ah, 2
	int 0x10
	dec ah
	mov cx, 0x607
	int 0x10

	pop cx
	pop es

	mov bx, 0
	;; analyser la saisie de l'utilisateur
inputbox_input:
	mov ah, 0
	int 0x16
	cmp ah, 0xe
	jz $inputbox_back
	cmp al, 13
	jz $inputbox_enter
	cmp cx, 0
	jz $inputbox_input
	cmp al, 32
	jnc $inputbox_char
	jmp $inputbox_input
inputbox_char:
	mov [es:di+bx], al
	mov ah, 0xe
	int 0x10
	dec cx
	inc bx
	jmp $inputbox_input
inputbox_back:
	cmp bx, 0
	jz $inputbox_input
	mov ah, 0xe
	mov al, 8
	int 0x10
	mov al, 95
	int 0x10
	mov al, 8
	int 0x10
	inc cx
	dec bx
	jmp $inputbox_input
inputbox_enter:
	mov byte [es:di+bx], 0

	;; effacer le curseur
	mov ah, 1
	mov cx, 0x100
	int 0x10

	pop bp
	pop dx
	pop cx
	pop bx
	pop ax
	ret

;;; +-------------------------------------------------------------------------+
;;; | Donnees                                                                 |
;;; +-------------------------------------------------------------------------+

main_win_title:
	.chaine "  MBRLoader v0.4-i386 - mbrloader@arnak.fr.st, www.arnak.fr.st/mbrloader        "
main_win_up:
	.chaine "ÚÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄż"
main_win_middle:
	.chaine "ł                                                                              ł"
main_win_down:
	.chaine "ŔÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄŮ"

dialog_title:
	.chaine "  MBRLoader v0.4-i386                   "
dialog_up:
	.chaine "ÚÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄż"
dialog_middle:
	.chaine "ł                                      ł"
dialog_down:
	.chaine "ŔÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄŮ"
textarea:
	.chaine "________________________________________"

;;; Gestion des items
selected_item:
	.octet 0
nb_items:
	.octet 0
items:
	;; 2 octets par items, avec les adresses (offsets uniquement)
	;; max de 21 items
	;; soit 52 octets au total
	.tampon 52
