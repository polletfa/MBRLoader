	mov [$config_str], $config_str_en
	mov [$part_str], $part_str_en
	mov ax, [$part_str_n_en]
	mov [$part_str_n], ax
	mov [$vol_str], $vol_str_en
	mov ax, [$vol_str_n_en]
	mov [$vol_str_n], ax
	mov [$additem_str], $additem_str_en
	mov [$delitem_str], $delitem_str_en
	mov [$autostart_str], $autostart_str_en
	mov [$langue_str], $langue_str_en
	mov [$inserez_mbrtb_disq], $inserez_mbrtb_disq_en
	mov [$pas_de_toolbox], $pas_de_toolbox_en
	mov [$toolbox_str], $toolbox_str_en
	mov [$savequit], $savequit_en
	mov [$quit], $quit_en
	mov [$annuler], $annuler_en
	mov [$systeme_inconnu], $systeme_inconnu_en
	mov [$label], $label_en
	mov [$liste_pleine], $liste_pleine_en
	mov [$empty_str], $empty_str_en
	mov [$autostart_oui], $autostart_oui_en
	mov [$autostart_non], $autostart_non_en
	mov [$vol_inconnu], $vol_inconnu_en
	mov [$vol_vide], $vol_vide_en
	mov [$systeme_inconnu], $systeme_inconnu_en
	pop ax
	ret

set_lang_de:
	push ax
	mov [$load_msg], $load_msg_de
	mov [$config_str], $config_str_de
	mov [$part_str], $part_str_de
	mov ax, [$part_str_n_de]
	mov [$part_str_n], ax
	mov [$vol_str], $vol_str_de
	mov ax, [$vol_str_n_de]
	mov [$vol_str_n], ax
