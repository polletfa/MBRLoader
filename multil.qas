	mov [$delitem_str], $delitem_str_de
	mov [$autostart_str], $autostart_str_de
	mov [$langue_str], $langue_str_de
	mov [$inserez_mbrtb_disq], $inserez_mbrtb_disq_de
	mov [$pas_de_toolbox], $pas_de_toolbox_de
	mov [$toolbox_str], $toolbox_str_de
	mov [$savequit], $savequit_de
	mov [$quit], $quit_de
	mov [$annuler], $annuler_de
	mov [$systeme_inconnu], $systeme_inconnu_de
	mov [$label], $label_de
	mov [$liste_pleine], $liste_pleine_de
	mov [$empty_str], $empty_str_de
	mov [$autostart_oui], $autostart_oui_de
	mov [$autostart_non], $autostart_non_de
	mov [$vol_inconnu], $vol_inconnu_de
	mov [$vol_vide], $vol_vide_de
	mov [$systeme_inconnu], $systeme_inconnu_de
	pop ax
	ret

;;; +-------------------------------------------------------------------------+
;;; | Pointeurs                                                               |
;;; +-------------------------------------------------------------------------+
load_msg:
	.mot 0
config_str:
	.mot 0
part_str:
	.mot 0
part_str_n:
	.mot 0
vol_str:
	.mot 0
vol_str_n:
	.mot 0
additem_str:
	.mot 0
delitem_str:
	.mot 0
autostart_str:
	.mot 0
langue_str:
	.mot 0
inserez_mbrtb_disq:
	.mot 0
pas_de_toolbox:
	.mot 0
toolbox_str:
	.mot 0
savequit:
	.mot 0
quit:
	.mot 0
annuler:
	.mot 0
label:
	.mot 0
liste_pleine:
	.mot 0
empty_str:
	.mot 0
autostart_oui:
	.mot 0
autostart_non:
	.mot 0
vol_inconnu:
	.mot 0
vol_vide:
	.mot 0
systeme_inconnu:
	.mot 0

.inclure "donnees.qas"
.inclure "datumoj.qas"
.inclure "data.qas"
.include "daten.qas"