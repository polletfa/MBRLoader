;;; +-------------------------------------------------------------------------+
;;; | set_lang                                                                |
;;; | al=langue (1=fr, 2=eo, 3=en, 4=de)                                      |
;;; +-------------------------------------------------------------------------+
set_lang:
	cmp al, 1
	jz $set_lang_fr
	cmp al, 2
	jz $set_lang_eo
	cmp al, 3
	jz $set_lang_en
	cmp al, 4
	jz $set_lang_de
	ret

set_lang_fr:
	push ax
	mov [$load_msg], $load_msg_fr
	mov [$config_str], $config_str_fr
	mov [$part_str], $part_str_fr
	mov ax, [$part_str_n_fr]
	mov [$part_str_n], ax
	mov [$vol_str], $vol_str_fr
	mov ax, [$vol_str_n_fr]
	mov [$vol_str_n], ax
	mov [$additem_str], $additem_str_fr
	mov [$delitem_str], $delitem_str_fr
	mov [$autostart_str], $autostart_str_fr
	mov [$langue_str], $langue_str_fr
	mov [$inserez_mbrtb_disq], $inserez_mbrtb_disq_fr
	mov [$pas_de_toolbox], $pas_de_toolbox_fr
	mov [$toolbox_str], $toolbox_str_fr
	mov [$savequit], $savequit_fr
	mov [$quit], $quit_fr
	mov [$annuler], $annuler_fr
	mov [$systeme_inconnu], $systeme_inconnu_fr
	mov [$label], $label_fr
	mov [$liste_pleine], $liste_pleine_fr
	mov [$empty_str], $empty_str_fr
	mov [$autostart_oui], $autostart_oui_fr
	mov [$autostart_non], $autostart_non_fr
	mov [$vol_inconnu], $vol_inconnu_fr
	mov [$vol_vide], $vol_vide_fr
	mov [$systeme_inconnu], $systeme_inconnu_fr
	pop ax
	ret

