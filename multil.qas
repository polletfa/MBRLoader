	push ax
	mov [$load_msg], $load_msg_eo
	mov [$config_str], $config_str_eo
	mov [$part_str], $part_str_eo
	mov ax, [$part_str_n_eo]
	mov [$part_str_n], ax
	mov [$vol_str], $vol_str_eo
	mov ax, [$vol_str_n_eo]
	mov [$vol_str_n], ax
	mov [$additem_str], $additem_str_eo
	mov [$delitem_str], $delitem_str_eo
	mov [$autostart_str], $autostart_str_eo
	mov [$langue_str], $langue_str_eo
	mov [$inserez_mbrtb_disq], $inserez_mbrtb_disq_eo
	mov [$pas_de_toolbox], $pas_de_toolbox_eo
	mov [$toolbox_str], $toolbox_str_eo
	mov [$savequit], $savequit_eo
	mov [$quit], $quit_eo
	mov [$annuler], $annuler_eo
	mov [$systeme_inconnu], $systeme_inconnu_eo
	mov [$label], $label_eo
	mov [$liste_pleine], $liste_pleine_eo
	mov [$empty_str], $empty_str_eo
	mov [$autostart_oui], $autostart_oui_eo
	mov [$autostart_non], $autostart_non_eo
	mov [$vol_inconnu], $vol_inconnu_eo
	mov [$vol_vide], $vol_vide_eo
	mov [$systeme_inconnu], $systeme_inconnu_eo
	pop ax
	ret

